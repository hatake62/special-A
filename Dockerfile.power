FROM python:3.11-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["sh", "-c", "if [ \"$OPT\" = \"1\" ]; then exec python bench/run_case.py constant_fold_array --opt --seconds 60; else exec python bench/run_case.py constant_fold_array --seconds 60; fi"]
